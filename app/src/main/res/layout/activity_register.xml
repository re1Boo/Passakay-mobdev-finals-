<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false">

    <include
        android:id="@+id/header"
        layout="@layout/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card background (taller to fit more fields) -->
    <View
        android:id="@+id/card_register"
        android:layout_width="226dp"
        android:layout_height="370dp"
        android:background="@drawable/rounded_card_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="200dp" />

    <!-- Mascot -->
    <ImageView
        android:id="@+id/img_mascot"
        android:layout_width="55dp"
        android:layout_height="73dp"
        android:src="@drawable/login_passakay_logo"
        android:scaleType="fitXY"
        android:contentDescription="Mascot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="150dp" />

    <!-- Create Account Title -->
    <ImageView
        android:id="@+id/tv_welcome"
        android:layout_width="116dp"
        android:layout_height="28dp"
        android:src="@drawable/welcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="220dp" />

    <!-- Student ID -->
    <EditText
        android:id="@+id/et_student_id"
        android:layout_width="171dp"
        android:layout_height="28dp"
        android:hint="Student ID"
        android:textColorHint="#D0D0D0"
        android:textSize="12sp"
        android:fontFamily="@font/kanit"
        android:textStyle="bold"
        android:background="@drawable/rounded_input_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="265dp" />

    <!-- Email -->
    <EditText
        android:id="@+id/et_email"
        android:layout_width="171dp"
        android:layout_height="28dp"
        android:hint="Email"
        android:textColorHint="#D0D0D0"
        android:textSize="12sp"
        android:fontFamily="@font/kanit"
        android:textStyle="bold"
        android:background="@drawable/rounded_input_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="textEmailAddress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="305dp" />

    <!-- Password -->
    <EditText
        android:id="@+id/et_password"
        android:layout_width="171dp"
        android:layout_height="28dp"
        android:hint="Password"
        android:textColorHint="#D0D0D0"
        android:textSize="12sp"
        android:fontFamily="@font/kanit"
        android:textStyle="bold"
        android:background="@drawable/rounded_input_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="textPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="345dp" />

    <!-- Confirm Password -->
    <EditText
        android:id="@+id/et_confirm_password"
        android:layout_width="171dp"
        android:layout_height="28dp"
        android:hint="Confirm Password"
        android:textColorHint="#D0D0D0"
        android:textSize="12sp"
        android:fontFamily="@font/kanit"
        android:textStyle="bold"
        android:background="@drawable/rounded_input_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="textPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="385dp" />

    <!-- Create Account Button -->
    <Button
        android:id="@+id/btn_register"
        android:layout_width="115dp"
        android:layout_height="28dp"
        android:text="Create Account"
        android:textColor="#000000"
        android:textSize="12sp"
        android:textStyle="bold"
        android:fontFamily="@font/kanit"
        android:background="@drawable/rounded_green_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="430dp" />

    <!-- Back to Login -->
    <TextView
        android:id="@+id/tv_back_to_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Already have an account? Login"
        android:textColor="#888888"
        android:textSize="10sp"
        android:fontFamily="@font/kanit"
        android:textStyle="normal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="470dp" />

</androidx.constraintlayout.widget.ConstraintLayout>