<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false">

    <include
        android:id="@+id/header"
        layout="@layout/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <View
                android:id="@+id/card_register"
                android:layout_width="280dp"
                android:layout_height="580dp"
                android:background="@drawable/rounded_card_bg"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="50dp" />

            <ImageView
                android:id="@+id/img_mascot"
                android:layout_width="55dp"
                android:layout_height="73dp"
                android:src="@drawable/login_passakay_logo"
                android:scaleType="fitXY"
                android:contentDescription="Mascot"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/card_register"
                android:layout_marginTop="-40dp" />

            <ImageView
                android:id="@+id/tv_welcome"
                android:layout_width="116dp"
                android:layout_height="28dp"
                android:src="@drawable/welcome"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/card_register"
                android:layout_marginTop="30dp" />

            <EditText
                android:id="@+id/et_first_name"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:hint="First Name"
                android:textColorHint="#D0D0D0"
                android:textSize="12sp"
                android:fontFamily="@font/kanit"
                android:textStyle="bold"
                android:background="@drawable/rounded_input_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="textPersonName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_welcome"
                android:layout_marginTop="20dp" />

            <EditText
                android:id="@+id/et_last_name"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:hint="Last Name"
                android:textColorHint="#D0D0D0"
                android:textSize="12sp"
                android:fontFamily="@font/kanit"
                android:textStyle="bold"
                android:background="@drawable/rounded_input_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="textPersonName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_first_name"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/et_student_id"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:hint="Student ID"
                android:textColorHint="#D0D0D0"
                android:textSize="12sp"
                android:fontFamily="@font/kanit"
                android:textStyle="bold"
                android:background="@drawable/rounded_input_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_last_name"
                android:layout_marginTop="12dp" />

            <Spinner
                android:id="@+id/sp_department"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:background="@drawable/rounded_input_bg"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_student_id"
                android:layout_marginTop="12dp" />

            <Spinner
                android:id="@+id/sp_course"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:background="@drawable/rounded_input_bg"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sp_department"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:hint="Email"
                android:textColorHint="#D0D0D0"
                android:textSize="12sp"
                android:fontFamily="@font/kanit"
                android:textStyle="bold"
                android:background="@drawable/rounded_input_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="textEmailAddress"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sp_course"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:hint="Password"
                android:textColorHint="#D0D0D0"
                android:textSize="12sp"
                android:fontFamily="@font/kanit"
                android:textStyle="bold"
                android:background="@drawable/rounded_input_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="textPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_email"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/et_confirm_password"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:hint="Confirm Password"
                android:textColorHint="#D0D0D0"
                android:textSize="12sp"
                android:fontFamily="@font/kanit"
                android:textStyle="bold"
                android:background="@drawable/rounded_input_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="textPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_password"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btn_register"
                android:layout_width="140dp"
                android:layout_height="36dp"
                android:text="Create Account"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/kanit"
                android:background="@drawable/rounded_green_btn"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/et_confirm_password"
                android:layout_marginTop="20dp" />

            <TextView
                android:id="@+id/tv_back_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? Login"
                android:textColor="#888888"
                android:textSize="10sp"
                android:fontFamily="@font/kanit"
                android:textStyle="normal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_register" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>