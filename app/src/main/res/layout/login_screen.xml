<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false">

    <View
        android:id="@+id/greenStripe"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:background="#14D337"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="63dp" />

    <View
        android:id="@+id/yellowStripe"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="#FFEA08"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="67dp" />

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="24dp"
        android:layout_height="32dp"
        android:src="@drawable/login_passakay_logo"
        android:scaleType="fitXY"
        android:contentDescription="102 (1) 1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="10dp"
        android:layout_marginTop="26dp" />

    <ImageView
        android:id="@+id/tvAppName"
        android:layout_width="145dp"
        android:layout_height="28dp"
        android:src="@drawable/login_passakay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="40dp"
        android:layout_marginTop="23dp" />

    <View
        android:id="@+id/cardLogin"
        android:layout_width="226dp"
        android:layout_height="303dp"
        android:background="@drawable/rounded_card_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="88dp"
        android:layout_marginTop="228dp"
    />

    <ImageView
        android:id="@+id/imgMascot"
        android:layout_width="55dp"
        android:layout_height="73dp"
        android:src="@drawable/login_passakay_logo"
        android:scaleType="fitXY"
        android:contentDescription="102 (1) 2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="173dp"
        android:layout_marginTop="177dp" />

    <ImageView
        android:id="@+id/tvWelcome"
        android:layout_width="116dp"
        android:layout_height="28dp"
        android:src="@drawable/login_welcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="149dp"
        android:layout_marginTop="249dp" />

    <EditText
        android:id="@+id/etStudentId"
        android:layout_width="171dp"
        android:layout_height="28dp"
        android:hint="Enter Student ID"
        android:textColorHint="#D0D0D0"
        android:textSize="12sp"
        android:fontFamily="@font/kanit"
        android:textStyle="bold"
        android:background="@drawable/rounded_input_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="115dp"
        android:layout_marginTop="310dp" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="171dp"
        android:layout_height="28dp"
        android:hint="Password"
        android:textColorHint="#D0D0D0"
        android:textSize="12sp"
        android:fontFamily="@font/kanit"
        android:textStyle="bold"
        android:background="@drawable/rounded_input_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="textPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="115dp"
        android:layout_marginTop="359dp" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="115dp"
        android:layout_height="28dp"
        android:text="Login"
        android:textColor="#000000"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="@font/kanit"
        android:background="@drawable/rounded_green_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="143dp"
        android:layout_marginTop="437dp" />
</androidx.constraintlayout.widget.ConstraintLayout>