<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="#FFFFFF">


    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <!-- Mascot + glow background -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp">

                <!-- Glow circle behind mascot -->
                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/circle_green_light"
                    android:layout_gravity="center"/>

                <ImageView
                    android:id="@+id/imgMascot"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/login_passakay_logo"
                    android:scaleType="fitCenter"
                    android:layout_gravity="center"
                    android:contentDescription="Passakay logo"/>

            </FrameLayout>

            <!-- App name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PaSSakay"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/kanit"
                android:layout_marginBottom="4dp"/>

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your campus shuttle companion"
                android:textSize="13sp"
                android:textColor="#888888"
                android:fontFamily="@font/kanit"
                android:layout_marginBottom="32dp"/>

            <!-- Login Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Welcome back text -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:fontFamily="@font/kanit"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign in to your account"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:fontFamily="@font/kanit"
                        android:layout_marginBottom="24dp"/>

                    <!-- Student ID label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student ID"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:fontFamily="@font/kanit"
                        android:layout_marginBottom="6dp"/>

                    <!-- Student ID input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/input_bg_modern"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person"
                            android:layout_marginEnd="10dp"
                            app:tint="#AAAAAA"/>

                        <EditText
                            android:id="@+id/etStudentId"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:fontFamily="@font/kanit"
                            android:hint="Enter your Student ID"
                            android:inputType="text"
                            android:textColorHint="#CCCCCC"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:importantForAutofill="no"/>

                    </LinearLayout>

                    <!-- Password label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:fontFamily="@font/kanit"
                        android:layout_marginBottom="6dp"/>

                    <!-- Password input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/input_bg_modern"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="24dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_lock"
                            android:layout_marginEnd="10dp"
                            app:tint="#AAAAAA"/>

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:fontFamily="@font/kanit"
                            android:hint="Enter your password"
                            android:inputType="textPassword"
                            android:textColorHint="#CCCCCC"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:importantForAutofill="no"/>

                        <!-- Show/hide password -->
                        <ImageView
                            android:id="@+id/ivTogglePassword"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_eye_off"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="#AAAAAA"/>

                    </LinearLayout>

                    <!-- Login Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Login"
                        android:textAllCaps="false"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/kanit"
                        app:backgroundTint="#14D337"
                        app:cornerRadius="12dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Divider -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="#E0E0E0"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  or  "
                            android:textColor="#AAAAAA"
                            android:textSize="12sp"
                            android:fontFamily="@font/kanit"/>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="#E0E0E0"/>

                    </LinearLayout>

                    <!-- Create account row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Don't have an account?  "
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:fontFamily="@font/kanit"/>

                        <TextView
                            android:id="@+id/btnCreateAccount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create one"
                            android:textColor="#14D337"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/kanit"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
