<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="#FFFFFF"
    android:clipChildren="false">

    <include
        android:id="@+id/header"
        layout="@layout/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/cardLogin"
        android:layout_width="226dp"
        android:layout_height="303dp"
        android:background="@drawable/rounded_card_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="88dp"
        android:layout_marginTop="228dp" />

    <ImageView
        android:id="@+id/imgMascot"
        android:layout_width="55dp"
        android:layout_height="73dp"
        android:src="@drawable/login_passakay_logo"
        android:scaleType="fitXY"
        android:contentDescription="102 (1) 2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="173dp"
        android:layout_marginTop="177dp" />

    <ImageView
        android:id="@+id/tvWelcome"
        android:layout_width="116dp"
        android:layout_height="28dp"
        android:src="@drawable/welcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="149dp"
        android:layout_marginTop="249dp" />

    <EditText
        android:id="@+id/etStudentId"
        android:layout_width="171dp"
        android:layout_height="28dp"
        android:hint="Enter Student ID"
        android:textColorHint="#D0D0D0"
        android:textSize="12sp"
        android:fontFamily="@font/kanit"
        android:textStyle="bold"
        android:background="@drawable/rounded_input_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="115dp"
        android:layout_marginTop="310dp" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="171dp"
        android:layout_height="28dp"
        android:hint="Password"
        android:textColorHint="#D0D0D0"
        android:textSize="12sp"
        android:fontFamily="@font/kanit"
        android:textStyle="bold"
        android:background="@drawable/rounded_input_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:inputType="textPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="115dp"
        android:layout_marginTop="359dp" />

    <!-- Updated Login Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnLogin"
        android:layout_width="115dp"
        android:layout_height="28dp"
        android:text="Login"
        android:textColor="#000000"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="@font/kanit"
        android:background="@drawable/rounded_green_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="143dp"
        android:layout_marginTop="407dp" />

    <!-- Subtle Create Account Text -->
    <TextView
        android:id="@+id/btnCreateAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account? Create one"
        android:textColor="#888888"
        android:textSize="10sp"
        android:fontFamily="@font/kanit"
        android:textStyle="normal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="445dp" />

</androidx.constraintlayout.widget.ConstraintLayout>