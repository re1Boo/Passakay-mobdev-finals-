<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header: Consistent with other pages -->
    <include
        android:id="@+id/headerInclude"
        layout="@layout/header"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Content Area with Bottom Sheet support -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinatorLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerInclude"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <!-- Map View as the background layer -->
        <com.google.android.gms.maps.MapView
            android:id="@+id/mapViewStops"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Draggable Bottom Sheet -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/bottomSheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/rounded_top_white"
            android:elevation="8dp"
            app:behavior_hideable="false"
            app:behavior_peekHeight="200dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- Drag handle -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="12dp"
                    android:background="#CCCCCC"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="12dp">

                    <!-- "Shuttle Stops" title -->
                    <TextView
                        android:id="@+id/tvStopsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shuttle Stops"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:fontFamily="@font/archivo_black"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"/>

                    <!-- Stop Driving Button -->
                    <Button
                        android:id="@+id/btnStopDriving"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Stop Driving"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#FF5252"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"/>

                </RelativeLayout>

                <!-- Stop items list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerStops"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Bottom Navigation: Anchored to the very bottom and always visible -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        app:elevation="16dp"
        app:menu="@menu/menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="#1A1A1A"
        app:itemIconSize="25dp"
        app:itemTextColor="#1A1A1A"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>