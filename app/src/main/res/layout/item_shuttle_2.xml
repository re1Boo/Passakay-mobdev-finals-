<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <!-- Main Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardShuttle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Top row: icon + info + Status Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="34dp"
                    android:src="@drawable/bus"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvBusName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bus 1"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvDriverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Driver: John Doe"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/tvPlateNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plate Number: ABC 1234"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                </LinearLayout>

                <!-- Status Button: yellow=Deployed, green=Standby, gray=Unavailable -->
                <Button
                    android:id="@+id/btnStatus"
                    android:layout_width="84dp"
                    android:layout_height="41dp"
                    android:text="Deployed"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:fontFamily="@font/archivo_black"
                    android:background="@drawable/rounded_yellow_badge"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Expandable Map Section -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMap"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF"
        android:layout_marginTop="4dp">

        <com.google.android.gms.maps.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:liteMode="true" />

    </androidx.cardview.widget.CardView>

</LinearLayout>