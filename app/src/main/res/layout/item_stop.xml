<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main Stop Info -->
        <LinearLayout
            android:id="@+id/layoutMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_location_pin"
                android:layout_marginEnd="12dp"
                android:contentDescription="Stop icon"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStopName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stop Name"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:id="@+id/tvWaiting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Waiting: 0"
                    android:textSize="11sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance: 0m"
                    android:textSize="11sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/ivExpand"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/arrow_down_float"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                android:contentDescription="Expand"/>

            <Button
                android:id="@+id/btnPickUp"
                android:layout_width="84dp"
                android:layout_height="41dp"
                android:text="Pick up"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:fontFamily="@font/archivo_black"
                android:background="@drawable/rounded_yellow_badge"
                android:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

        </LinearLayout>

        <!-- Expandable Passenger List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPassengers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="48dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>