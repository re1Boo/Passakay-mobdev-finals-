<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="75dp"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="24dp"
        android:layout_height="32dp"
        android:src="@drawable/login_passakay_logo"
        android:scaleType="fitXY"
        android:contentDescription="Logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/greenStripe"
        android:layout_marginStart="10dp"/>

    <ImageView
        android:id="@+id/tvAppName"
        android:layout_width="145dp"
        android:layout_height="28dp"
        android:src="@drawable/passakay_name"
        app:layout_constraintStart_toEndOf="@id/imgLogo"
        app:layout_constraintTop_toTopOf="@id/imgLogo"
        app:layout_constraintBottom_toBottomOf="@id/imgLogo"
        android:layout_marginStart="6dp"/>

    <View
        android:id="@+id/greenStripe"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:background="#14D337"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <View
        android:id="@+id/yellowStripe"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="#FFEA08"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="10dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>